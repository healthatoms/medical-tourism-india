datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Patient {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String
  firstName     String
  lastName      String
  phone         String?
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("patients")
}

model Hospital {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  description   String?   @db.Text
  city          String
  state         String
  country       String    @default("India")
  address       String
  phone         String
  email         String
  website       String?
  image         String?
  rating        Float     @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("hospitals")
}

model MedicalSystem {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  description   String?   @db.Text
  image         String?
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("medical_systems")
}

model Service {
  id              Int       @id @default(autoincrement())
  name            String
  description     String?   @db.Text
  category        String
  image           String?
  estimatedCost   Float
  estimatedStay   Int
  medicalSystemId Int
  hospitalId      Int
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("services")
}

model VideoTestimonial {
  id            Int       @id @default(autoincrement())
  patientName   String
  country       String
  title         String
  description   String?   @db.Text
  videoUrl      String
  thumbnailUrl  String?
  procedure     String
  rating        Int
  published     Boolean   @default(false)
  views         Int       @default(0)
  featured      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("video_testimonials")
}