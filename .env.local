# MySQL Connection
DATABASE_URL="mysql://username:password@your_hostinger_mysql_host:3306/database_name"

# API
NEXT_PUBLIC_API_URL=http://localhost:3000

# Authentication
NEXTAUTH_SECRET=your_very_secure_random_string_here
